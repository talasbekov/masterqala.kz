NODE_ENV="development"
PORT="3000"
DATABASE_URL="postgresql://masterqala:masterqala@localhost:5432/masterqala"

# Обязательный секрет длиной не менее 32 символов.
# Сгенерируйте отдельное случайное значение для каждого окружения, например:
# openssl rand -base64 48
JWT_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

# Разрешённые browser origins через запятую, без path.
# В production допускаются только HTTPS origins и значение обязательно.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Количество доверенных reverse-proxy hops до API.
# 0 — прямое подключение; 1 — один Nginx/Caddy/ingress перед приложением.
# Не завышайте значение: от него зависит достоверность request.ip и rate limiting.
TRUST_PROXY_HOPS="0"

OPERATOR_PHONE="+77000000001"
UPLOAD_DIR="./uploads"

# Сколько часов непривязанное фото доступно владельцу для создания заявки.
# Допустимо 1–168. После TTL путь нельзя использовать и cleanup удалит файл.
UPLOAD_TTL_HOURS="24"

# Проверка файлов: DISABLED | CLAMAV.
# DISABLED разрешён только для development/test. В production обязателен CLAMAV.
FILE_SCAN_MODE="DISABLED"
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT="3310"
CLAMAV_TIMEOUT_MS="15000"
UPLOAD_SCAN_MAX_ATTEMPTS="3"

# Политика PDF документов мастера: BYPASS | REQUIRED.
# В production значение задаётся явно.
# REQUIRED временно запрещает PDF, пока CDR-провайдер не подключён.
# BYPASS разрешает PDF после ClamAV и фиксирует cdrStatus=BYPASSED.
PDF_CDR_MODE="BYPASS"

# Security audit хранится 30–3650 дней. Default: 365.
SECURITY_AUDIT_RETENTION_DAYS="365"
# Метаданные terminal quarantine и неуспешные бинарники: 1–365 дней.
FILE_QUARANTINE_RETENTION_DAYS="30"
# После consume удаляется только временная PendingUpload-запись; файл заявки остаётся.
# Допустимо 1–365 дней.
CONSUMED_UPLOAD_METADATA_RETENTION_DAYS="30"

# Коммерческий режим: FREE_PILOT | PAID_MOCK | PAID_LIVE
# Для первой публичной версии используйте FREE_PILOT.
# Если переменная отсутствует, код оставляет PAID_MOCK для обратной совместимости тестов и разработки.
COMMERCIAL_MODE="FREE_PILOT"

# Тарифы срочного режима (в FREE_PILOT рассчитываются только как номинальная аналитика)
# PRICING_BASE_FARE=2000
# PRICING_PER_KM=150
# SERVICE_FEE_RATE=0.4
# SERVICE_FEE_MIN=1000
# Отключение pg-boss (используется в e2e)
# PGBOSS_DISABLED=1
