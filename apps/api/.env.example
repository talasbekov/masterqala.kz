DATABASE_URL="postgresql://masterqala:masterqala@localhost:5432/masterqala"
JWT_SECRET="dev-secret-change-me"
OPERATOR_PHONE="+77000000001"
UPLOAD_DIR="./uploads"

# Коммерческий режим: FREE_PILOT | PAID_MOCK | PAID_LIVE
# Для первой публичной версии используйте FREE_PILOT.
# Если переменная отсутствует, код оставляет PAID_MOCK для обратной совместимости тестов и разработки.
COMMERCIAL_MODE="FREE_PILOT"

# Тарифы срочного режима (в FREE_PILOT рассчитываются только как номинальная аналитика)
# PRICING_BASE_FARE=2000
# PRICING_PER_KM=150
# SERVICE_FEE_RATE=0.4
# SERVICE_FEE_MIN=1000
# Отключение pg-boss (используется в e2e)
# PGBOSS_DISABLED=1
