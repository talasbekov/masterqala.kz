{
  "name": "@masterqala/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./tokens-client-v2.css": "./src/tokens-client-v2.css",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src/tokens.css",
    "src/tokens-client-v2.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external react-dom && tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
